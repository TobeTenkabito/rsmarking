# =============================================================
# RSMarking - 环境变量配置示例
# 使用方法：复制本文件为 .env，填入你的真实 Key
# =============================================================


# -------------------------------------------------------------
# 🔷 OpenAI (GPT-4o, GPT-4-turbo, GPT-3.5 等)
# 获取地址：https://platform.openai.com/api-keys
# 文档：https://platform.openai.com/docs
# -------------------------------------------------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1        # 使用代理时替换此项
OPENAI_MODEL=gpt-4o                              # 可选: gpt-4-turbo / gpt-3.5-turbo


# -------------------------------------------------------------
# 🟣 Anthropic Claude (Claude 3.5 Sonnet, Claude 3 Opus 等)
# 获取地址：https://console.anthropic.com/settings/keys
# 文档：https://docs.anthropic.com
# -------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_BASE_URL=https://api.anthropic.com     # 使用代理时替换此项
ANTHROPIC_MODEL=claude-sonnet-4-6                # 可选: claude-3-opus-20240229


# -------------------------------------------------------------
# 🔵 Google Gemini (Gemini 1.5 Pro, Gemini 1.5 Flash 等)
# 获取地址：https://aistudio.google.com/app/apikey
# 文档：https://ai.google.dev/docs
# -------------------------------------------------------------
GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com
GOOGLE_MODEL=gemini-1.5-pro                      # 可选: gemini-1.5-flash


# -------------------------------------------------------------
# 🟡 DeepSeek (DeepSeek-V3, DeepSeek-R1 等)
# 获取地址：https://platform.deepseek.com/api_keys
# 文档：https://platform.deepseek.com/docs
# 兼容 OpenAI SDK，base_url 替换即可
# -------------------------------------------------------------
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat                     # 可选: deepseek-reasoner (R1)


# -------------------------------------------------------------
# 🟠 阿里云通义千问 (Qwen-Max, Qwen-Plus, Qwen-Turbo 等)
# 获取地址：https://dashscope.console.aliyun.com/apiKey
# 文档：https://help.aliyun.com/zh/dashscope
# 兼容 OpenAI SDK，base_url 替换即可
# -------------------------------------------------------------
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-max                         # 可选: qwen-plus / qwen-turbo


# -------------------------------------------------------------
# 🔴 字节跳动火山引擎 (Doubao, DeepSeek 托管版等)
# 获取地址：https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
# 文档：https://www.volcengine.com/docs/82379
# -------------------------------------------------------------
ARK_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-pro-4k                          # 填写你的接入点 endpoint ID


# -------------------------------------------------------------
# 🟤 百度文心一言 (ERNIE-4.0, ERNIE-Speed 等)
# 获取地址：https://console.bce.baidu.com/qianfan/ais/console/applicationConsole/application
# 文档：https://cloud.baidu.com/doc/WENXINWORKSHOP
# -------------------------------------------------------------
QIANFAN_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
QIANFAN_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
QIANFAN_MODEL=ERNIE-4.0-8K                       # 可选: ERNIE-Speed-8K


# -------------------------------------------------------------
# ⚙️ 应用通用配置
# -------------------------------------------------------------
# 当前激活的 AI 提供商，对应上方各节前缀
# 可选值: openai | anthropic | google | deepseek | dashscope | ark | qianfan
AI_MODEL= "your model"

# 请求超时（毫秒）
AI_TIMEOUT=30000

# 最大 token 数
AI_MAX_TOKENS=4096

AI_API_KEY = "your key"