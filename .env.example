# =============================================================
# RSMarking - 环境变量配置示例
# 使用方法：复制本文件为 .env，填入你的真实 Key
# =============================================================


# -------------------------------------------------------------
# 🔷 OpenAI (GPT-4o, GPT-4-turbo, GPT-3.5 等)
# 获取地址：https://platform.openai.com/api-keys
# 文档：https://platform.openai.com/docs
# -------------------------------------------------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1        # 使用代理时替换此项
# Legacy fallback only; prefer AI_MODEL in the general section below.
# OPENAI_MODEL=gpt-4o


# -------------------------------------------------------------
# 🟣 Anthropic Claude (Claude 3.5 Sonnet, Claude 3 Opus 等)
# 获取地址：https://console.anthropic.com/settings/keys
# 文档：https://docs.anthropic.com
# -------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_BASE_URL=https://api.anthropic.com     # 使用代理时替换此项
ANTHROPIC_MODEL=claude-sonnet-4-6                # 可选: claude-3-opus-20240229


# -------------------------------------------------------------
# 🔵 Google Gemini (Gemini 1.5 Pro, Gemini 1.5 Flash 等)
# 获取地址：https://aistudio.google.com/app/apikey
# 文档：https://ai.google.dev/docs
# -------------------------------------------------------------
GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com
GOOGLE_MODEL=gemini-1.5-pro                      # 可选: gemini-1.5-flash


# -------------------------------------------------------------
# 🟡 DeepSeek (DeepSeek-V3, DeepSeek-R1 等)
# 获取地址：https://platform.deepseek.com/api_keys
# 文档：https://platform.deepseek.com/docs
# 兼容 OpenAI SDK，base_url 替换即可
# -------------------------------------------------------------
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat                     # 可选: deepseek-reasoner (R1)


# -------------------------------------------------------------
# 🟠 阿里云通义千问 (Qwen-Max, Qwen-Plus, Qwen-Turbo 等)
# 获取地址：https://dashscope.console.aliyun.com/apiKey
# 文档：https://help.aliyun.com/zh/dashscope
# 兼容 OpenAI SDK，base_url 替换即可
# -------------------------------------------------------------
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-max                         # 可选: qwen-plus / qwen-turbo


# -------------------------------------------------------------
# 🔴 字节跳动火山引擎 (Doubao, DeepSeek 托管版等)
# 获取地址：https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
# 文档：https://www.volcengine.com/docs/82379
# -------------------------------------------------------------
ARK_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-pro-4k                          # 填写你的接入点 endpoint ID


# -------------------------------------------------------------
# 🟤 百度文心一言 (ERNIE-4.0, ERNIE-Speed 等)
# 获取地址：https://console.bce.baidu.com/qianfan/ais/console/applicationConsole/application
# 文档：https://cloud.baidu.com/doc/WENXINWORKSHOP
# -------------------------------------------------------------
QIANFAN_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
QIANFAN_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
QIANFAN_MODEL=ERNIE-4.0-8K                       # 可选: ERNIE-Speed-8K


# -------------------------------------------------------------
# ⚙️ 应用通用配置
# -------------------------------------------------------------
# The AI Gateway uses AI_MODEL as the single active model setting.
# Provider-specific *_MODEL values above are examples for reference.
# 当前激活的模型。推荐使用 LiteLLM 格式: provider/model
# 示例: openai/gpt-4o | openai/o3-mini | deepseek/deepseek-chat | deepseek/deepseek-reasoner | dashscope/qwen3-plus
AI_MODEL=deepseek/deepseek-chat

# Optional image-generation model used by the generate_ai_image agent tool.
# Simple diagrams can always be exported as safe SVG without this setting.
# AI_IMAGE_MODEL=openai/gpt-image-1
# AI_IMAGE_DOWNLOAD_TIMEOUT=30
# AI_ARTIFACT_DIR=storage/ai_artifacts

# 可选：覆盖 provider 自动推断。通常不需要设置。
# AI_PROVIDER=deepseek

# 可选：全局覆盖 API key / base URL。未设置时会按 provider 读取 DEEPSEEK_API_KEY、OPENAI_API_KEY 等。
# AI_API_KEY=
# AI_BASE_URL=

# 请求超时（毫秒）
AI_TIMEOUT=30000

# 最大 token 数
AI_MAX_TOKENS=4096

# -------------------------------------------------------------
# Optional Thinking / Reasoning Mode
# 默认关闭。只有在启用且模型/提供商被识别为支持 reasoning/thinking 时才会传递参数。
# -------------------------------------------------------------
AI_REASONING_ENABLED=false

# OpenAI reasoning models (o1/o3/o4/gpt-5 等) 使用 reasoning_effort。
# 常见值: low | medium | high
AI_REASONING_EFFORT=medium

# Provider-specific style. auto 会根据 provider/model 选择:
# openai -> reasoning_effort
# anthropic -> thinking={type,budget_tokens}
# dashscope/qwen -> extra_body={enable_thinking,thinking_budget}
# custom -> 仅使用 AI_REASONING_EXTRA_JSON
AI_REASONING_STYLE=auto

# Anthropic / Qwen 等模型可用的 thinking token budget。
# AI_REASONING_BUDGET_TOKENS=2048

# 可选：显式声明哪些模型支持 reasoning。支持 * 通配符。
# 未设置时仅使用内置安全 allowlist，避免向普通模型发送不兼容参数。
# AI_REASONING_MODEL_ALLOWLIST=openai/o3-*,deepseek/deepseek-reasoner,dashscope/qwen3-*

# 可选：高级 provider 适配参数，JSON 对象，会合并到 LiteLLM 调用参数中。
# 示例: {"extra_body":{"enable_thinking":true}}
# AI_REASONING_EXTRA_JSON=
